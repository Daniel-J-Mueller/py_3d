{
  "name": "slime_fluid",
  "description": "Bounded deformable slime-fluid blobs with surface tension, wetting, and stickiness parameters.",
  "rendering_dir": "USER/environments/slime_fluid/renderings",
  "baking_dir": "USER/environments/slime_fluid/baking",
  "render_data": "USER/environments/slime_fluid/render-data.json",
  "renders": [
    {
      "name": "still",
      "seconds": 0,
      "outputs": ["USER/environments/slime_fluid/renderings/slime_fluid.png"],
      "command": [
        "python",
        "examples/slime_fluid_demo.py",
        "--output",
        "USER/environments/slime_fluid/renderings/slime_fluid.png",
        "--width",
        "480",
        "--height",
        "270",
        "--gamma",
        "1.12",
        "--warmup",
        "0.3"
      ]
    },
    {
      "name": "video",
      "seconds": 10,
      "outputs": ["USER/environments/slime_fluid/renderings/slime_fluid.mp4"],
      "command": [
        "python",
        "examples/slime_fluid_demo.py",
        "--video",
        "USER/environments/slime_fluid/renderings/slime_fluid.mp4",
        "--frames",
        "240",
        "--fps",
        "24",
        "--width",
        "480",
        "--height",
        "270",
        "--gamma",
        "1.12"
      ]
    }
  ]
}
