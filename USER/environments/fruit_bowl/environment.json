{
  "name": "fruit_bowl",
  "description": "Kinematic fruit bowl scene with direct py_3d live navigation and full render variants.",
  "rendering_dir": "USER/environments/fruit_bowl/renderings",
  "baking_dir": "USER/environments/fruit_bowl/baking",
  "render_data": "USER/environments/fruit_bowl/render-data.json",
  "live": {
    "default": [
      "python",
      "examples/fruit_bowl_live.py",
      "--renderer",
      "py_gpu",
      "--light-mode",
      "hanging-lamp"
    ],
    "mirror_prelight": [
      "python",
      "examples/fruit_bowl_live.py",
      "--renderer",
      "py_gpu",
      "--width",
      "1920",
      "--height",
      "1080",
      "--max-render-distance",
      "12.0",
      "--window-width",
      "1920",
      "--window-height",
      "1080",
      "--gamma",
      "1.15",
      "--quality",
      "ultra",
      "--fps",
      "0",
      "--no-vsync",
      "--sphere-segments",
      "24",
      "--sphere-rings",
      "12",
      "--bowl-material",
      "mirror",
      "--light-mode",
      "mirror-prelight"
    ],
    "poly_lamp": [
      "python",
      "examples/fruit_bowl_live.py",
      "--renderer",
      "py_gpu",
      "--width",
      "1280",
      "--height",
      "720",
      "--max-render-distance",
      "9.0",
      "--window-width",
      "1280",
      "--window-height",
      "720",
      "--gamma",
      "1.12",
      "--quality",
      "poly",
      "--fps",
      "0",
      "--no-vsync",
      "--sphere-segments",
      "7",
      "--sphere-rings",
      "4",
      "--no-smooth-shading",
      "--bowl-material",
      "wood",
      "--light-mode",
      "poly-lamp",
      "--label",
      "POLY WOOD LAMP"
    ],
    "rgb_bulbs": [
      "python",
      "examples/fruit_bowl_rgb_bulbs_live.py",
      "--renderer",
      "py_gpu"
    ],
    "cpu_preview": [
      "python",
      "examples/fruit_bowl_live.py",
      "--renderer",
      "cpu",
      "--width",
      "320",
      "--height",
      "180",
      "--window-width",
      "960",
      "--window-height",
      "540",
      "--sphere-segments",
      "10",
      "--sphere-rings",
      "5"
    ]
  },
  "renders": [
    {
      "name": "pipeline",
      "seconds": 10,
      "outputs": [
        "USER/environments/fruit_bowl/renderings/fruit_bowl_poly.mp4",
        "USER/environments/fruit_bowl/renderings/fruit_bowl_smooth.mp4",
        "USER/environments/fruit_bowl/renderings/fruit_bowl_ray_traced.mp4",
        "USER/environments/fruit_bowl/renderings/fruit_bowl_mirror_prelight.mp4"
      ],
      "command": [
        "python",
        "examples/render_fruit_bowl_variants.py",
        "--output-dir",
        "USER/environments/fruit_bowl/renderings",
        "--max-render-distance",
        "7.0"
      ]
    },
    {
      "name": "fast_gpu_still",
      "seconds": 0,
      "outputs": ["USER/environments/fruit_bowl/renderings/fruit_bowl_gpu_fast.png"],
      "command": [
        "python",
        "examples/fruit_bowl_demo.py",
        "--renderer",
        "py_gpu",
        "--gpu-fast-render",
        "--output",
        "USER/environments/fruit_bowl/renderings/fruit_bowl_gpu_fast.png",
        "--width",
        "480",
        "--height",
        "270",
        "--smooth-shading",
        "--gamma",
        "1.15",
        "--sphere-segments",
        "16",
        "--sphere-rings",
        "8",
        "--max-render-distance",
        "7.0"
      ]
    },
    {
      "name": "live_parity_still",
      "seconds": 0,
      "outputs": ["USER/environments/fruit_bowl/renderings/fruit_bowl_live_parity.png"],
      "command": [
        "python",
        "examples/fruit_bowl_demo.py",
        "--renderer",
        "py_gpu",
        "--output",
        "USER/environments/fruit_bowl/renderings/fruit_bowl_live_parity.png",
        "--width",
        "480",
        "--height",
        "270",
        "--smooth-shading",
        "--gamma",
        "1.15",
        "--sphere-segments",
        "18",
        "--sphere-rings",
        "9"
      ]
    }
  ]
}
